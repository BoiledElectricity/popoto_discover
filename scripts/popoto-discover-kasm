#!/usr/bin/env bash
set -euo pipefail

IMAGE="${POPOTO_KASM_IMAGE:-registry.popotomodem.com/delresearch/popoto_discover-kasm:latest}"
CONTAINER="${POPOTO_KASM_CONTAINER:-popoto-discover-kasm}"
DATA_DIR="${POPOTO_KASM_DATA:-$HOME/.local/share/popoto-discover-kasm}"
POPOTO_REPO="${POPOTO_REPO:-https://github.com/BoiledElectricity/popoto_discover.git}"
POPOTO_BRANCH="${POPOTO_BRANCH:-main}"
TITLE="${POPOTO_KASM_TITLE:-Popoto Discover}"
cmd="${1:-}"
arg_downloads="${2:-}"
DOWNLOADS_DIR="${POPOTO_DOWNLOADS:-${arg_downloads:-$HOME/Downloads}}"

usage() {
  cat <<EOF
usage: $0 <command> [downloads-folder]

commands:
  start [downloads-folder]  Start or restart the browser desktop.
  stop                      Stop the container.
  restart [downloads-folder] Restart the container.
  update [downloads-folder] Pull the newest image and restart.
  logs                      Follow container logs.
  status                    Show container status.
  build                     Build ${IMAGE}.
  push                      Push ${IMAGE}.
  rm                        Remove the container.

environment:
  POPOTO_KASM_IMAGE      Image to run/build/push. Default: ${IMAGE}
  POPOTO_KASM_CONTAINER  Container name. Default: ${CONTAINER}
  POPOTO_KASM_DATA       Persistent cache/work/config root. Default: ${DATA_DIR}
  POPOTO_DOWNLOADS       Host folder mounted as /downloads. Default: ${DOWNLOADS_DIR}
  POPOTO_REPO            App source repo. Default: ${POPOTO_REPO}
  POPOTO_BRANCH          App source branch. Default: ${POPOTO_BRANCH}

browser:
  http://localhost:3000
EOF
}

require_docker() {
  command -v docker >/dev/null 2>&1 || {
    echo "docker is required" >&2
    exit 1
  }
}

prepare_dirs() {
  mkdir -p "$DATA_DIR/cache" "$DATA_DIR/work" "$DATA_DIR/config" "$DOWNLOADS_DIR"
}

container_exists() {
  docker container inspect "$CONTAINER" >/dev/null 2>&1
}

container_running() {
  [ "$(docker container inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null || true)" = "true" ]
}

run_container() {
  prepare_dirs
  if container_running; then
    docker stop "$CONTAINER" >/dev/null
  fi
  if container_exists; then
    docker rm "$CONTAINER" >/dev/null
  fi

  docker run -d \
    --name "$CONTAINER" \
    --restart unless-stopped \
    --network host \
    --cap-add NET_RAW \
    --cap-add NET_ADMIN \
    --security-opt seccomp=unconfined \
    -e PUID=0 \
    -e PGID=0 \
    -e TZ="${TZ:-America/New_York}" \
    -e POPOTO_REPO="$POPOTO_REPO" \
    -e POPOTO_BRANCH="$POPOTO_BRANCH" \
    -e TITLE="$TITLE" \
    -v "$DATA_DIR/cache:/opt/popoto-discover/cache" \
    -v "$DATA_DIR/work:/opt/popoto-discover/work" \
    -v "$DATA_DIR/config:/config" \
    -v "$DOWNLOADS_DIR:/downloads" \
    "$IMAGE" >/dev/null

  cat <<EOF
Popoto Discover Kasm is starting.
URL:       http://localhost:3000
Container: $CONTAINER
Downloads: $DOWNLOADS_DIR -> /downloads
Logs:      $0 logs
Stop:      $0 stop
EOF
}

case "$cmd" in
  start)
    require_docker
    docker image inspect "$IMAGE" >/dev/null 2>&1 || docker pull "$IMAGE"
    run_container
    ;;
  stop)
    require_docker
    docker stop "$CONTAINER" >/dev/null 2>&1 || true
    echo "Stopped $CONTAINER"
    ;;
  restart)
    require_docker
    run_container
    ;;
  update)
    require_docker
    docker pull "$IMAGE"
    run_container
    ;;
  logs)
    require_docker
    docker logs -f "$CONTAINER"
    ;;
  status)
    require_docker
    docker ps -a --filter "name=^/${CONTAINER}$"
    ;;
  build)
    require_docker
    docker build -f docker/kasm/Dockerfile -t "$IMAGE" .
    ;;
  push)
    require_docker
    docker push "$IMAGE"
    ;;
  rm)
    require_docker
    docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
    echo "Removed $CONTAINER"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
